# Crystal
/lib/
/bin/
/.shards/
*.dwarf
shard.override.yml

# Local release binaries (built by `make build` / `make release` / `make lb`).
/rinha_de_backend
/rinha_lb

# Compiled vendored C objects (Makefile + Dockerfile rebuild on demand).
*.o

